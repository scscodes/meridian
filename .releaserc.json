{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["semantic-release-vsce", {
      "packageVsix": true,
      "publish": true
    }],
    ["@semantic-release/github", {
      "assets": [
        { "path": "*.vsix", "label": "Extension (VSIX)" }
      ]
    }]
  ]
}

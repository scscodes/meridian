{
  "name": "meridian",
  "displayName": "Meridian",
  "description": "AI-powered git analytics, code hygiene, workflow engine, and chat assistant for VS Code",
  "version": "1.0.0",
  "publisher": "scscodes",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/scscodes/meridian"
  },
  "categories": [
    "Programming Languages",
    "SCM Providers",
    "Machine Learning"
  ],
  "keywords": [
    "git",
    "hygiene",
    "code-review",
    "ai",
    "workflow",
    "copilot"
  ],
  "engines": {
    "node": ">=22.22.0",
    "vscode": "^1.91.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/main.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "meridian-explorer",
          "title": "Meridian",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "meridian-explorer": [
        {
          "id": "meridian.git.view",
          "name": "Git"
        },
        {
          "id": "meridian.hygiene.view",
          "name": "Hygiene"
        },
        {
          "id": "meridian.workflow.view",
          "name": "Workflows"
        },
        {
          "id": "meridian.agent.view",
          "name": "Agents"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "meridian",
        "name": "meridian",
        "fullName": "Meridian",
        "description": "Git, hygiene, workflow, and agent assistant for your workspace",
        "isDefault": false,
        "commands": [
          {
            "name": "status",
            "description": "Show current git branch and file change counts"
          },
          {
            "name": "scan",
            "description": "Scan workspace for hygiene issues (large files, dead files, logs)"
          },
          {
            "name": "workflows",
            "description": "List all available Meridian workflows"
          },
          {
            "name": "agents",
            "description": "List all available Meridian agents and their capabilities"
          },
          {
            "name": "analytics",
            "description": "Open the Git Analytics report"
          },
          {
            "name": "context",
            "description": "Show workspace context: branch, active file, and available commands"
          },
          {
            "name": "pr",
            "description": "Generate a pull request description for the current branch"
          },
          {
            "name": "review",
            "description": "Review current branch changes — verdict and per-file comments"
          },
          {
            "name": "briefing",
            "description": "Generate a session briefing: branch state, recent commits, uncommitted work"
          },
          {
            "name": "conflicts",
            "description": "Suggest resolution strategies for detected git conflicts"
          },
          {
            "name": "impact",
            "description": "Trace the blast radius of a file or function change"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "meridian_git_status",
        "displayName": "Meridian: Git Status",
        "modelDescription": "Check the current git branch, whether the working tree is dirty, and counts of staged, unstaged, and untracked files.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_smart_commit",
        "displayName": "Meridian: Smart Commit",
        "modelDescription": "Automatically group staged file changes by semantic type, suggest commit messages, and commit all groups in batch.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_analyze_inbound",
        "displayName": "Meridian: Analyze Inbound Changes",
        "modelDescription": "Fetch and analyze incoming changes from the remote branch, detecting conflicts and summarizing diffs before merging.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_hygiene_scan",
        "displayName": "Meridian: Hygiene Scan",
        "modelDescription": "Scan the workspace for hygiene issues such as unused files, dead code, and oversized log files.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_workflow_run",
        "displayName": "Meridian: Run Workflow",
        "modelDescription": "Execute a named workflow from the .vscode/workflows/ directory. Use meridian_workflow_list first if you don't know the workflow name.",
        "inputSchema": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "description": "The exact name of the workflow to run"
            }
          }
        }
      },
      {
        "name": "meridian_git_show_analytics",
        "displayName": "Meridian: Git Analytics",
        "modelDescription": "Generate a git analytics report covering commit frequency, code churn, author contributions, and file volatility metrics.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "period": {
              "type": "string",
              "enum": [
                "3mo",
                "6mo",
                "12mo"
              ],
              "description": "Time period for the analytics report. Defaults to 3mo."
            }
          }
        }
      },
      {
        "name": "meridian_chat_delegate",
        "displayName": "Meridian: Delegate Task",
        "modelDescription": "Route a natural language task description to the appropriate Meridian command. Use when you need to analyze, review, brief, or perform a git/hygiene operation but don't know the exact command. Provide a clear task description and Meridian will classify and execute the right command.",
        "inputSchema": {
          "type": "object",
          "required": [
            "task"
          ],
          "properties": {
            "task": {
              "type": "string",
              "description": "Natural language description of what you want to do (e.g. 'generate a PR description', 'review my changes', 'session briefing')"
            }
          }
        }
      },
      {
        "name": "meridian_git_generate_pr",
        "displayName": "Meridian: Generate PR",
        "modelDescription": "Generate a pull request description from the current branch changes, including title, summary, and change breakdown.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_review_pr",
        "displayName": "Meridian: Review PR",
        "modelDescription": "Review current branch changes and return a verdict (approve/request-changes) with per-file comments and severity ratings.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_comment_pr",
        "displayName": "Meridian: Comment PR",
        "modelDescription": "Generate inline code review comments for changed files in the current branch.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_resolve_conflicts",
        "displayName": "Meridian: Resolve Conflicts",
        "modelDescription": "Detect git merge conflicts and suggest resolution strategies per file, including rationale for each recommendation.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_session_briefing",
        "displayName": "Meridian: Session Briefing",
        "modelDescription": "Generate a session briefing covering branch state, recent commits, uncommitted work, and suggested next steps.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_hygiene_impact",
        "displayName": "Meridian: Impact Analysis",
        "modelDescription": "Trace the blast radius of a file or function change using TypeScript Compiler API. Returns importers, call sites, test coverage, and a prose summary.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Absolute or relative path to the TypeScript file to analyze"
            },
            "functionName": {
              "type": "string",
              "description": "Optional function or symbol name to trace call sites for"
            }
          },
          "required": [
            "filePath"
          ]
        }
      },
      {
        "name": "meridian_agent_execute",
        "displayName": "Meridian: Execute Agent",
        "modelDescription": "Execute a registered agent with a target command or workflow. Use meridian_agent_list first to discover available agents and their capabilities.",
        "inputSchema": {
          "type": "object",
          "required": [
            "agentId"
          ],
          "properties": {
            "agentId": {
              "type": "string",
              "description": "The ID of the agent to execute"
            },
            "targetCommand": {
              "type": "string",
              "description": "The command to execute (must be in agent's capabilities list)"
            },
            "targetWorkflow": {
              "type": "string",
              "description": "The workflow to execute (alternative to targetCommand)"
            }
          }
        }
      },
      {
        "name": "meridian_workflow_list",
        "displayName": "Meridian: List Workflows",
        "modelDescription": "List all available workflows defined in .vscode/workflows/. Returns names, descriptions, and step counts. Call this before meridian_workflow_run when you don't know the workflow name.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_agent_list",
        "displayName": "Meridian: List Agents",
        "modelDescription": "List all registered agents defined in .vscode/agents/. Returns agent IDs, descriptions, and capabilities. Call this before meridian_agent_execute when you don't know the agent ID.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "meridian_git_export_json",
        "displayName": "Meridian: Export Git Analytics (JSON)",
        "modelDescription": "Export the git analytics report data as a JSON file.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "period": {
              "type": "string",
              "enum": [
                "3mo",
                "6mo",
                "12mo"
              ],
              "description": "Time period for the analytics report. Defaults to 3mo."
            },
            "author": {
              "type": "string",
              "description": "Optional: filter analytics by author name."
            },
            "pathPattern": {
              "type": "string",
              "description": "Optional: filter analytics by file path glob pattern."
            }
          }
        }
      },
      {
        "name": "meridian_git_export_csv",
        "displayName": "Meridian: Export Git Analytics (CSV)",
        "modelDescription": "Export the git analytics report data as a CSV file.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "period": {
              "type": "string",
              "enum": [
                "3mo",
                "6mo",
                "12mo"
              ],
              "description": "Time period for the analytics report. Defaults to 3mo."
            },
            "author": {
              "type": "string",
              "description": "Optional: filter analytics by author name."
            },
            "pathPattern": {
              "type": "string",
              "description": "Optional: filter analytics by file path glob pattern."
            }
          }
        }
      }
    ],

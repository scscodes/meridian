    "configuration": {
      "title": "Meridian",
      "properties": {
        "meridian.model.default": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default language model family for all Meridian AI features (e.g. gpt-4o, claude-3-5-sonnet). Used when no domain-specific override is set."
        },
        "meridian.model.hygiene": {
          "type": "string",
          "default": "",
          "description": "Language model family for hygiene domain (markdown review). Empty = inherits meridian.model.default."
        },
        "meridian.model.git": {
          "type": "string",
          "default": "",
          "description": "Language model family for git domain (commit messages, diff analysis). Empty = inherits meridian.model.default."
        },
        "meridian.model.chat": {
          "type": "string",
          "default": "",
          "description": "Language model family for @meridian chat participant direct LLM calls. Empty = inherits meridian.model.default."
        },
        "meridian.hygiene.prune.minAgeDays": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Minimum file age in days for a file to be considered a prune candidate."
        },
        "meridian.hygiene.prune.maxSizeMB": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "Files larger than this size (MB) are flagged as prune candidates when also older than minAgeDays."
        },
        "meridian.hygiene.prune.minLineCount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Flag files with this many lines or more as prune candidates (when also older than minAgeDays). Set to 0 to disable."
        },
        "meridian.hygiene.prune.categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "markdown",
              "log",
              "config",
              "backup",
              "temp",
              "source",
              "artifact",
              "other"
            ]
          },
          "default": [
            "backup",
            "temp",
            "log",
            "artifact"
          ],
          "description": "File categories that are automatically flagged as prune candidates when older than minAgeDays."
        },
        "meridian.git.autofetch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fetch from remote before git operations."
        },
        "meridian.git.branchClean": {
          "type": "boolean",
          "default": true,
          "description": "Automatically clean merged branches after pull."
        },
        "meridian.hygiene.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace hygiene scanning."
        },
        "meridian.hygiene.scanInterval": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Interval in minutes between automatic hygiene scans."
        },
        "meridian.chat.model": {
          "type": "string",
          "default": "gpt-4",
          "description": "Default language model for chat operations."
        },
        "meridian.chat.contextLines": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Number of lines of context to include from the active file in chat requests."
        },
        "meridian.log.level": {
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Minimum log level for the Meridian output channel."
        }
      }
    },
    "keybindings": [
      {
        "command": "meridian.git.smartCommit",
        "key": "ctrl+m ctrl+c",
        "mac": "cmd+m cmd+c",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.hygiene.scan",
        "key": "ctrl+m ctrl+s",
        "mac": "cmd+m cmd+s",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.showAnalytics",
        "key": "ctrl+m ctrl+a",
        "mac": "cmd+m cmd+a",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.refreshAll",
        "key": "ctrl+m ctrl+r",
        "mac": "cmd+m cmd+r",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.generatePR",
        "key": "ctrl+m ctrl+p",
        "mac": "cmd+m cmd+p",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.reviewPR",
        "key": "ctrl+m ctrl+v",
        "mac": "cmd+m cmd+v",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.commentPR",
        "key": "ctrl+m ctrl+i",
        "mac": "cmd+m cmd+i",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.resolveConflicts",
        "key": "ctrl+m ctrl+x",
        "mac": "cmd+m cmd+x",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.git.sessionBriefing",
        "key": "ctrl+m ctrl+b",
        "mac": "cmd+m cmd+b",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "meridian.hygiene.impactAnalysis",
        "key": "ctrl+m ctrl+t",
        "mac": "cmd+m cmd+t",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {

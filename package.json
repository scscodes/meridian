        {
          "command": "meridian.refreshAll",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "view/title": [
        {
          "command": "meridian.git.refresh",
          "when": "view == meridian.git.view",
          "group": "navigation"
        },
        {
          "command": "meridian.hygiene.refresh",
          "when": "view == meridian.hygiene.view",
          "group": "navigation"
        },
        {
          "command": "meridian.workflow.refresh",
          "when": "view == meridian.workflow.view",
          "group": "navigation"
        },
        {
          "command": "meridian.agent.refresh",
          "when": "view == meridian.agent.view",
          "group": "navigation"
        },
        {
          "command": "meridian.git.showAnalytics",
          "when": "view == meridian.git.view",
          "group": "navigation"
        },
        {
          "command": "meridian.hygiene.showAnalytics",
          "when": "view == meridian.hygiene.view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "meridian.git.smartCommit",
          "when": "view == meridian.git.view && viewItem == branch",
          "group": "git@1"
        },
        {
          "command": "meridian.git.pull",
          "when": "view == meridian.git.view && viewItem == branch",
          "group": "git@2"
        },
        {
          "command": "meridian.hygiene.cleanup",
          "when": "view == meridian.hygiene.view && viewItem =~ /file/",
          "group": "hygiene@1"
        },
        {
          "command": "meridian.hygiene.deleteFile",
          "when": "view == meridian.hygiene.view && viewItem =~ /file/",
          "group": "hygiene@2"
        },
        {
          "command": "meridian.hygiene.ignoreFile",
          "when": "view == meridian.hygiene.view && viewItem =~ /file/",
          "group": "hygiene@3"
        },
        {
          "command": "meridian.hygiene.reviewFile",
          "when": "view == meridian.hygiene.view && viewItem == markdownFile",
          "group": "hygiene@4"
        },
        {
          "command": "meridian.workflow.run",
          "when": "view == meridian.workflow.view && viewItem == workflow",
          "group": "workflow@1"
        },
        {
          "command": "meridian.agent.run",
          "when": "view == meridian.agent.view && viewItem == agent",
          "group": "agent@1"
        }
      ],
      "view/item/inline": [
        {
          "command": "meridian.workflow.run",
          "when": "view == meridian.workflow.view && viewItem == workflow",
          "group": "inline"
        },
        {
          "command": "meridian.agent.run",
          "when": "view == meridian.agent.view && viewItem == agent",
          "group": "inline"
        },
        {
          "command": "meridian.git.showAnalytics",
          "when": "view == meridian.git.view && viewItem == branch",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild src/main.ts --bundle --outfile=out/main.js --external:vscode --external:typescript --format=cjs --platform=node --target=node20 && cp -r media out/media 2>/dev/null || true && cp -r bundled out/bundled 2>/dev/null || true && mkdir -p out/domains/git && rm -rf out/domains/git/analytics-ui && cp -r src/domains/git/analytics-ui out/domains/git/analytics-ui && mkdir -p out/domains/hygiene && rm -rf out/domains/hygiene/analytics-ui && cp -r src/domains/hygiene/analytics-ui out/domains/hygiene/analytics-ui",
    "compile": "tsc -p ./ && cp -r media out/media 2>/dev/null || true && cp -r bundled out/bundled 2>/dev/null || true && mkdir -p out/domains/git && rm -rf out/domains/git/analytics-ui && cp -r src/domains/git/analytics-ui out/domains/git/analytics-ui && mkdir -p out/domains/hygiene && rm -rf out/domains/hygiene/analytics-ui && cp -r src/domains/hygiene/analytics-ui out/domains/hygiene/analytics-ui",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "lint": "echo 'Linting would run here'",
    "release": "semantic-release"
  },
  "dependencies": {
    "micromatch": "^4.0.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.0",
    "@types/vscode": "^1.80.0",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "esbuild": "^0.25.12",
    "semantic-release": "^24.2.9",
    "semantic-release-vsce": "^6.1.0",
    "vitest": "^1.0.4"
  }
}
